{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RCBrowser",
  "version": "1.1.7",
  "identifier": "com.royalcodex.browser.v1",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RCBROWSING",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src * 'unsafe-inline' 'unsafe-eval'; script-src * 'unsafe-inline' 'unsafe-eval'; connect-src * 'unsafe-inline'; img-src * data: blob: 'unsafe-inline'; frame-src *; style-src * 'unsafe-inline'; font-src * data:;"
    }
  },
  "bundle": {
    "active": true,
    "publisher": "Royal Codex Software Solutions",
    "targets": [
      "msi",
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "certificateThumbprint": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://raw.githubusercontent.com/Sethika-manu/dev-web/main/update.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVFODFGQTNGMjM5QjVGMjcKUldRblg1c2pQL3FCWHJrZnFINlQvZUxRSFhiQUhsMXNUaERRKzlaWXBrTmxKU2pEdVc3QytUNzIK"
    }
  }
}